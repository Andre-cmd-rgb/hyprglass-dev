{
  "layer": "top",
  "position": "top",
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,
  "height": 36,
  "spacing": 6,
  "modules-left": ["custom/logo", "hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "custom/bluetooth", "pulseaudio", "battery", "custom/laptop", "custom/power"],
  "custom/logo": {"format": "Hyprglass", "tooltip": false},
  "hyprland/workspaces": {"format": "{name}", "persistent-workspaces": {"*": 5}},
  "clock": {"format": "{:%a %d %b  %H:%M}", "tooltip-format": "{:%A, %d %B %Y}"},
  "network": {"format-wifi": "  {essid}", "format-ethernet": "󰈀 wired", "format-disconnected": "󰤭 offline", "on-click": "kitty --class hyprglass-float --title 'Hyprglass :: Wi-Fi' -e hyprglass wifi"},
  "custom/bluetooth": {"exec": "hyprglass bluetooth --status", "interval": 10, "return-type": "json", "on-click": "kitty --class hyprglass-float --title 'Hyprglass :: Bluetooth' -e hyprglass bluetooth"},
  "pulseaudio": {"format": "  {volume}%", "format-muted": "󰝟 muted", "on-click": "kitty --class hyprglass-float --title 'Hyprglass :: Audio' -e hyprglass audio"},
  "battery": {"format": "{icon} {capacity}%", "format-charging": "󰂄 {capacity}%", "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"], "on-click": "kitty --class hyprglass-float --title 'Hyprglass :: Laptop' -e hyprglass laptop"},
  "custom/laptop": {"format": "󰌢", "tooltip": "Laptop controls", "on-click": "kitty --class hyprglass-float --title 'Hyprglass :: Laptop' -e hyprglass laptop"},
  "custom/power": {"format": "⏻", "tooltip": "Power actions are intentionally manual in V0", "on-click": "kitty --class hyprglass-float --title 'Hyprglass :: Power' -e hyprglass power"}
}
